@echo off\necho ==========================================\necho \ud83c\udfe0 Futrix AI - First Time Setup\necho ==========================================\necho.\necho This script will help you set up Futrix AI for the first time.\necho Please follow the prompts carefully.\necho.\npause\n\nREM Check if we're in the right directory\nif not exist \"package.json\" if not exist \"node-api\" (\n    echo \u274c Error: Please run this script from the Futrix AI root directory\n    echo Expected to find: node-api/, client/, python-ai/, java-gateway/\n    pause\n    exit /b 1\n)\n\necho \ud83d\udd0d Step 1: Checking system requirements...\necho.\n\nREM Check Node.js\nnode --version >nul 2>&1\nif errorlevel 1 (\n    echo \u274c Node.js not found\n    echo Please install Node.js 18+ from: https://nodejs.org/\n    pause\n    exit /b 1\n) else (\n    for /f \"tokens=*\" %%i in ('node --version') do echo \u2705 Node.js: %%i\n)\n\nREM Check Python\npython --version >nul 2>&1\nif errorlevel 1 (\n    echo \u274c Python not found\n    echo Please install Python 3.9+ from: https://python.org/\n    pause\n    exit /b 1\n) else (\n    for /f \"tokens=*\" %%i in ('python --version') do echo \u2705 Python: %%i\n)\n\nREM Check Java\njava -version >nul 2>&1\nif errorlevel 1 (\n    echo \u274c Java not found\n    echo Please install Java 11+ from: https://openjdk.org/\n    pause\n    exit /b 1\n) else (\n    echo \u2705 Java: Found\n)\n\nREM Check Maven\nmvn --version >nul 2>&1\nif errorlevel 1 (\n    echo \u274c Maven not found\n    echo Please install Apache Maven from: https://maven.apache.org/\n    pause\n    exit /b 1\n) else (\n    echo \u2705 Maven: Found\n)\n\nREM Check MongoDB\necho.\necho \ud83d\udcbe Checking MongoDB...\nmongo --version >nul 2>&1\nif errorlevel 1 (\n    echo \u26a0\ufe0f MongoDB CLI not found\n    echo Please ensure MongoDB is installed and running\n    echo Download from: https://www.mongodb.com/try/download/community\n    echo.\n    echo \ud83d\udca1 Alternative: You can use MongoDB Atlas (cloud) instead\n    echo Just update the MONGO_URI in the .env file later\n) else (\n    echo \u2705 MongoDB CLI: Found\n)\n\necho.\necho \ud83d\udd27 Step 2: Installing dependencies...\necho.\n\nREM Install Node API dependencies\necho Installing Node API dependencies...\ncd node-api\ncall npm install\nif errorlevel 1 (\n    echo \u274c Failed to install Node API dependencies\n    cd ..\n    pause\n    exit /b 1\n)\ncd ..\necho \u2705 Node API dependencies installed\n\nREM Install Client dependencies\necho Installing Client dependencies...\ncd client\ncall npm install\nif errorlevel 1 (\n    echo \u274c Failed to install Client dependencies\n    cd ..\n    pause\n    exit /b 1\n)\ncd ..\necho \u2705 Client dependencies installed\n\nREM Install Python dependencies\necho Installing Python AI dependencies...\ncd python-ai\npip install -r requirements.txt\nif errorlevel 1 (\n    echo \u274c Failed to install Python AI dependencies\n    cd ..\n    pause\n    exit /b 1\n)\ncd ..\necho \u2705 Python AI dependencies installed\n\necho.\necho \ud83d\udd10 Step 3: Setting up environment files...\necho.\n\nREM Setup Node API .env\nif not exist \"node-api\\.env\" (\n    echo Creating node-api/.env from template...\n    copy \"node-api\\.env.example\" \"node-api\\.env\"\n    echo \u2705 Created node-api/.env\n) else (\n    echo \u2139\ufe0f node-api/.env already exists\n)\n\nREM Setup Client .env\nif not exist \"client\\.env\" (\n    echo Creating client/.env...\n    echo VITE_GOOGLE_CLIENT_ID=424357134168-gtnpk168sp23oopec177581sb62vs6o0.apps.googleusercontent.com > \"client\\.env\"\n    echo VITE_API_URL=http://localhost:5000 >> \"client\\.env\"\n    echo \u2705 Created client/.env\n) else (\n    echo \u2139\ufe0f client/.env already exists\n)\n\necho.\necho \ud83d\udd11 Step 4: Google OAuth Setup\necho.\necho For Google OAuth to work, you need to:\necho 1. Go to: https://console.cloud.google.com/\necho 2. Create a new project or select existing one\necho 3. Enable Google+ API\necho 4. Create OAuth 2.0 credentials\necho 5. Add authorized origins: http://localhost:5173\necho 6. Copy the Client ID and Client Secret\necho.\necho \ud83d\udca1 The current setup uses demo credentials that may not work\necho.\nset /p \"setup_oauth=Do you want to set up your own Google OAuth credentials now? (y/n): \"\nif /i \"%setup_oauth%\"==\"y\" (\n    echo.\n    set /p \"client_id=Enter your Google Client ID: \"\n    set /p \"client_secret=Enter your Google Client Secret: \"\n    \n    REM Update node-api .env\n    powershell -Command \"(Get-Content 'node-api\\.env') -replace 'GOOGLE_CLIENT_ID=.*', 'GOOGLE_CLIENT_ID=!client_id!' | Set-Content 'node-api\\.env'\"\n    powershell -Command \"(Get-Content 'node-api\\.env') -replace 'GOOGLE_CLIENT_SECRET=.*', 'GOOGLE_CLIENT_SECRET=!client_secret!' | Set-Content 'node-api\\.env'\"\n    \n    REM Update client .env\n    powershell -Command \"(Get-Content 'client\\.env') -replace 'VITE_GOOGLE_CLIENT_ID=.*', 'VITE_GOOGLE_CLIENT_ID=!client_id!' | Set-Content 'client\\.env'\"\n    \n    echo \u2705 OAuth credentials updated\n) else (\n    echo \u2139\ufe0f Skipping OAuth setup - you can configure this later\n)\n\necho.\necho \ud83d\udcbe Step 5: Database Setup\necho.\nset /p \"mongo_uri=Enter MongoDB URI (press Enter for default localhost): \"\nif not \"%mongo_uri%\"==\"\" (\n    powershell -Command \"(Get-Content 'node-api\\.env') -replace 'MONGO_URI=.*', 'MONGO_URI=%mongo_uri%' | Set-Content 'node-api\\.env'\"\n    echo \u2705 MongoDB URI updated\n) else (\n    echo \u2139\ufe0f Using default MongoDB URI: mongodb://localhost:27017/futrixai\n)\n\necho.\necho \ud83d\udd0d Step 6: Running validation...\nnode validate-env.js\nif errorlevel 1 (\n    echo.\n    echo \u26a0\ufe0f Some configuration issues were found\n    echo Please review the validation results above\n    echo You can continue with the setup or fix these issues first\n    echo.\n    set /p \"continue_setup=Continue anyway? (y/n): \"\n    if /i not \"!continue_setup!\"==\"y\" (\n        echo Setup cancelled. Run this script again after fixing the issues.\n        pause\n        exit /b 1\n    )\n)\n\necho.\necho ==========================================\necho \u2705 Setup Complete!\necho ==========================================\necho.\necho \ud83c\udf89 Futrix AI has been set up successfully!\necho.\necho \ud83d\ude80 Next steps:\necho 1. Make sure MongoDB is running\necho 2. Run: start-dev.bat to start all services\necho 3. Open http://localhost:5173 in your browser\necho 4. Test the login functionality\necho.\necho \ud83d\udcda Useful commands:\necho   \u2022 start-dev.bat     - Start all services\necho   \u2022 validate-env.js   - Validate configuration\necho   \u2022 health-check.js   - Check service health\necho.\necho \ud83d\udd17 Documentation:\necho   \u2022 README.md              - Project overview\necho   \u2022 AUTH_TROUBLESHOOTING.md - Authentication help\necho.\nset /p \"start_now=Would you like to start the application now? (y/n): \"\nif /i \"%start_now%\"==\"y\" (\n    echo.\n    echo Starting Futrix AI...\n    call start-dev.bat\n) else (\n    echo.\n    echo Setup complete! Run 'start-dev.bat' when you're ready to start.\n)\n\npause